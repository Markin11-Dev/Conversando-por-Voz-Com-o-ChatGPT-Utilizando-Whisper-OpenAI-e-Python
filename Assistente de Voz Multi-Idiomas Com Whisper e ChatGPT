    {
      "cell_type": "code",
      "source": [
        "import openai\n",
        "\n",
        "# Configura a chave de API da OpenAI usando a variável de ambiente 'OPENAI_API_KEY'\n",
        "# Certifique-se de que a variável de ambiente OPENAI_API_KEY está definida corretamente.\n",
        "client = openai.OpenAI(\n",
        "    api_key=os.environ.get('OPENAI_API_KEY'),\n",
        ")\n",
        "\n",
        "# Envia uma requisição à API do ChatCompletion usando o modelo GPT-4\n",
        "# A variável 'transcription' contém a transcrição do nosso áudio.\n",
        "response = client.chat.completions.create(\n",
        "    model=\"gpt-4\",\n",
        "    messages=[ { \"role\": \"user\", \"content\": transcription } ]\n",
        ")\n",
        "\n",
        "# Obtém a resposta gerada pelo ChatGPT\n",
        "chatgpt_response = response.choices[0].message.content\n",
        "print(chatgpt_response)"
      ],
